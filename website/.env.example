# Discord OAuth2
DISCORD_CLIENT_ID=your_discord_application_client_id
DISCORD_CLIENT_SECRET=your_discord_application_client_secret
DISCORD_REDIRECT_URI=http://localhost:5000/callback

# Flask
FLASK_SECRET=change_this_to_a_random_secret

# Database (shared with the bot)
db_host=localhost
db_user=root
db_password=your_db_password
db_name=hockey

# Bot owner Discord user ID
BOT_OWNER_ID=920797181034778655

# Bot token (for the bot process, not the web dashboard)
token=your_bot_token_here
topgg-token=your_topgg_token_here
