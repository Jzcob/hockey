# Hockey Bot Website — Environment Variables
# Copy this file to .env.local and fill in the values.

# NextAuth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET=your_nextauth_secret_here

# Discord OAuth2
# Create an app at https://discord.com/developers/applications
# Add http://localhost:3000/api/auth/callback/discord to Redirects
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# Discord Bot Client ID (used for the "Add to Server" invite links)
NEXT_PUBLIC_BOT_CLIENT_ID=your_discord_bot_client_id

# MySQL Database (same credentials as the bot)
DB_HOST=localhost
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=hockey

# Public URL (used for OAuth2 redirects in production)
NEXTAUTH_URL=http://localhost:3000
